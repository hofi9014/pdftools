# Klucze API iLovePDF — https://developer.ilovepdf.com/
ILOVEPDF_PUBLIC_KEY=
ILOVEPDF_SECRET_KEY=

# Klucz API OpenRouter — https://openrouter.ai/keys
# Zarejestruj sie, utworz klucz i wklej go ponizej.
OPENROUTER_API_KEY=

# URL strony (uzywany w sitemap/robots)
NEXT_PUBLIC_SITE_URL=https://optimapdf.com

# Google Drive Picker API — https://console.cloud.google.com/
# 1. Utwórz projekt, włącz Google Picker API i Google Drive API
# 2. Utwórz klucz API (OAuth 2.0 Web Client ID, restrict domeną)
# 3. Skonfiguruj OAuth consent screen (External, dodaj scope: .../auth/drive.file)
NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_DRIVE_API_KEY=

# Dropbox Chooser — https://www.dropbox.com/developers/apps
# 1. Utwórz app typu "Dropbox API" z "Full Dropbox" access
# 2. Skopiuj App Key
NEXT_PUBLIC_DROPBOX_APP_KEY=

# OneDrive File Picker — https://portal.azure.com/ (Microsoft Entra ID)
# 1. Zarejestruj aplikację, dodaj platformę "Single-page application"
# 2. Dodaj redirect URI: https://optimapdf.com
# 3. Skopiuj Client ID (Application ID)
NEXT_PUBLIC_ONEDRIVE_CLIENT_ID=e1fe6dd8-ba31-4d61-89e7-88639da4683d

# HMAC secret do podpisywania krótkotrwałych URL-i eksportu (Dropbox Saver)
# Wygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXPORT_LINK_HMAC_SECRET=
